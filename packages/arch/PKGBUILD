pkgbase=vpn-passthrough
pkgname=('vpn-passthrough-cli' 'vpn-passthrough-pia' 'vpn-passthrough-dummy')
pkgver=0.1.0
pkgrel=1
arch=('x86_64')
url="https://github.com/radium226/vpn-passthrough"
license=('MIT')
makedepends=('uv' 'python-installer' 'python-wheel' 'python-build' 'python-uv-build')

# For AUR: replace with the real git URL.
# For local builds: the PKGBUILD uses the parent workspace directly (no source download).
source=(
    "vpn-passthrough.service"
    "vpn-passthrough@.service"
    "vpn-passthrough-ifconfig-me@.service"
    "vpn-passthrough.socket"
    "vpn-passthrough.sysusers"
    "vpn-passthrough.tmpfiles"
    "radium226_vpn_passthrough_app-0.1.0.tar.gz"
    "radium226_vpn_passthrough_messages-0.1.0.tar.gz"
    "radium226_vpn_passthrough_client-0.1.0.tar.gz"
    "radium226_vpn_passthrough_server-0.1.0.tar.gz"
    "radium226_vpn_passthrough_ipc-0.1.0.tar.gz"
    "radium226_vpn_passthrough_vpn-0.1.0.tar.gz"
    "radium226_vpn_passthrough_pia-0.1.0.tar.gz"
    "radium226_vpn_passthrough_dummy-0.1.0.tar.gz"
)
